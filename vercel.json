{
  "version": 2,
  "builds": [
    {
      "src": "apps/backend/api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "packages/database/prisma/schema.prisma",
          "node_modules/tree-sitter-wasms/out/*.wasm"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/backend/api/index.ts"
    }
  ]
}
